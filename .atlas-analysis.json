  "projectName": "lazygit",
  "projectDescription": "A simple terminal UI for git commands that makes complex git operations accessible through an intuitive keyboard-driven interface.",
  "theme": "aspen",
  "primaryColor": "#848484",
  "lightColor": "#141414",
  "darkColor": "#cbcbcb",
