  "keyFeatures": [
    "Interactive staging of individual lines and hunks",
    "Interactive rebase with squash, fixup, drop, and edit operations",
    "Cherry-pick commits across branches",
    "Git bisect support for finding bugs",
    "Undo/redo using git reflog",
    "Custom command keybindings with template syntax",
    "Worktree management for parallel branch work",
    "Custom patch building and rebase magic",
    "Stacked branches support with rebase.updateRefs",
    "Custom pager integration (delta, diff-so-fancy, ydiff)",
    "GitHub pull request integration via gh CLI",
    "Commit graph visualization"
  ],
  "publicApiSurface": [
    "lazygit (CLI entry point)",
    "lazygit --debug",
    "lazygit --logs",
    "lazygit --work-tree <path>",
    "lazygit --git-dir <path>",
    "customCommands config key",
    "keybinding contexts: global, files, branches, commits, stash, localBranches, remotes, tags, worktrees",
    "config.yml: gui, git, update, refresher, reporting, splashUpdatesIndex, confirmOnQuit, quitOnTopLevelReturn, services, notARepository, promptToReturnFromSubprocess"
  ]
